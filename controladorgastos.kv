
<MenuLateral>:
    title: ""
    title_size: 0
    separator_height: 0
    size_hint: 0.75, 1
    pos_hint: {'x': 0, 'top': 1}
    background_color: 0.1, 0.12, 0.16, 1

    MDBoxLayout:
        orientation: 'vertical'
        padding: [20, 30, 20, 20]
        spacing: 20
        
        MDRaisedButton:
            text: "Permissões"
            size_hint_x: 1
            height: "48dp"
            on_release: root.dismiss(); app.mudar_tela('configuracoes')

        
# ... dentro do MDBoxLayout do <MenuLateral> ...
        MDRaisedButton:
            text: "Histórico"
            size_hint_x: 1
            height: "48dp"
            on_release: root.dismiss(); app.mudar_tela('visualizacao')

        # NOVO BOTÃO DE TESTE DE INFRAESTRUTURA
        MDRaisedButton:
            text: "Lab: Testar Notificações"
            md_bg_color: 0.4, 0.4, 0.4, 1
            size_hint_x: 1
            height: "48dp"
            on_release: root.dismiss(); app.mudar_tela('testador_notificacao')

        # Cabeçalho integrado de forma limpa
        MDBoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: "60dp"
            spacing: 5
            
            MDLabel:
                text: "Controlador"
                font_style: 'H5'
                bold: True
                halign: "left"
            
            MDSeparator:
                ms_bg_color: 0.2, 0.25, 0.35, 1

        # Grupo de Navegação Principal
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 12
            size_hint_y: None
            height: self.minimum_height

            MDRaisedButton:
                text: "Item Único"
                size_hint_x: 1
                height: "48dp"
                on_release: root.dismiss(); app.mudar_tela('cadastro')

            MDRaisedButton:
                text: "Inserir em Massa"
                size_hint_x: 1
                height: "48dp"
                on_release: root.dismiss(); app.mudar_tela('cadastro_massa')

            MDRaisedButton:
                text: "Histórico"
                size_hint_x: 1
                height: "48dp"
                on_release: root.dismiss(); app.mudar_tela('visualizacao')

        # Espaçador único para empurrar o botão de saída ao rodapé de forma orgânica
        Widget:
            size_hint_y: 1

        MDRaisedButton:
            text: "Sair"
            md_bg_color: 0.8, 0.2, 0.2, 1
            size_hint_x: 1
            height: "48dp"
            on_release: root.dismiss(); app.encerrar_app()

<PopupEditar>:
    title: "Editar Despesa"
    size_hint: 0.95, 0.65
    auto_dismiss: False

    MDBoxLayout:
        orientation: 'vertical'
        padding: 15
        spacing: 15

        MDTextField:
            id: txt_cat
            hint_text: "Categoria"
            mode: "rectangle"
        
        MDTextField:
            id: txt_desc
            hint_text: "Descrição"
            mode: "rectangle"

        MDTextField:
            id: txt_val
            hint_text: "Valor (R$)"
            mode: "rectangle"
            input_filter: 'float'

        MDBoxLayout:
            size_hint_y: None
            height: "50dp"
            spacing: 10
            MDRaisedButton:
                text: "Cancelar"
                md_bg_color: 0.3, 0.3, 0.3, 1
                size_hint_x: 0.5
                on_release: root.dismiss()
            MDRaisedButton:
                text: "Salvar"
                md_bg_color: 0.1, 0.6, 0.4, 1
                size_hint_x: 0.5
                on_release: root.salvar_alteracao(txt_cat.text, txt_desc.text, txt_val.text)

<TelaCadastro>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.08, 0.09, 0.12, 1

        MDFloatLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: 0.11, 0.13, 0.18, 1

            MDRaisedButton:
                text: "MENU"
                pos_hint: {"x": 0.04, "center_y": 0.5}
                on_release: app.abrir_menu()

            MDLabel:
                text: "Novo Item"
                font_style: "H6"
                bold: True
                halign: "center"
                valign: "middle"
                pos_hint: {"center_x": 0.5, "center_y": 0.5}

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            MDBoxLayout:
                orientation: 'vertical'
                padding: [20, 24, 20, 20]
                spacing: 24
                size_hint_y: None
                height: self.minimum_height
                
                MDTextField:
                    id: txt_cat
                    hint_text: "Categoria (Ex: Alimentação)"
                    mode: "rectangle"

                MDTextField:
                    id: txt_desc
                    hint_text: "Descrição (Ex: Pizza)"
                    mode: "rectangle"

                MDTextField:
                    id: txt_val
                    hint_text: "Valor (Ex: 50.00)"
                    mode: "rectangle"
                    input_filter: 'float'

                Widget:
                    size_hint_y: None
                    height: "20dp"

                MDRaisedButton:
                    text: "Gravar Registro"
                    md_bg_color: 0.1, 0.6, 0.4, 1
                    size_hint_x: 1
                    size_hint_y: None
                    height: "50dp"
                    on_press: root.adicionar_gasto(txt_cat, txt_desc, txt_val)

<TelaCadastroMassa>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.08, 0.09, 0.12, 1

        MDFloatLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: 0.11, 0.13, 0.18, 1

            MDRaisedButton:
                text: "MENU"
                pos_hint: {"x": 0.04, "center_y": 0.5}
                on_release: app.abrir_menu()

            MDLabel:
                text: "Entrada em Massa"
                font_style: "H6"
                bold: True
                halign: "center"
                valign: "middle"
                pos_hint: {"center_x": 0.5, "center_y": 0.5}

        # ScrollView adicionado para permitir rolagem da tela inteira sem travar no input
        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            MDBoxLayout:
                orientation: 'vertical'
                padding: [20, 24, 20, 20]
                spacing: 20
                size_hint_y: None
                height: self.minimum_height

                # ... (resto do código)
                MDTextField:
                    id: txt_cat_massa
                    hint_text: "Categoria Base"
                    mode: "rectangle"
                    size_hint_y: None
                    height: "56dp"
                    
                MDTextField:
                    id: txt_bloco
                    multiline: True
                    # hint_text simplificado para não bugar o rótulo flutuante
                    hint_text: "Itens (formato: Descrição, Valor)" 
                    mode: "rectangle"
                    size_hint_y: None
                    height: "220dp"
                # ... (resto do código)

                Widget:
                    size_hint_y: None
                    height: "10dp"

                MDRaisedButton:
                    text: "Processar Tudo"
                    size_hint_x: 1
                    size_hint_y: None
                    height: "50dp"
                    on_release: root.processar_massa(txt_cat_massa.text, txt_bloco.text)

<TelaVisualizacao>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.08, 0.09, 0.12, 1

        MDFloatLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: 0.11, 0.13, 0.18, 1

            MDBoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: "190dp", "40dp"
                pos_hint: {"x": 0.04, "center_y": 0.5}
                spacing: 8

                MDRaisedButton:
                    text: "MENU"
                    on_release: app.abrir_menu()
                MDRaisedButton:
                    id: btn_voltar
                    text: "VOLTAR"
                    on_release: root.voltar_nivel()

            MDLabel:
                id: lbl_titulo_contexto
                text: "Análise de Gastos"
                font_style: "H6"
                bold: True
                halign: "right"
                valign: "middle"
                pos_hint: {"right": 0.96, "center_y": 0.5}

        MDBoxLayout:
            orientation: 'vertical'
            padding: [20, 20, 20, 20]
            size_hint_y: 1

            ScrollView:
                MDGridLayout:
                    id: grid_lista
                    cols: 1
                    spacing: 10
                    size_hint_y: None
                    height: self.minimum_height

<TelaTestadorNotificacao>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.08, 0.09, 0.12, 1

        MDFloatLayout:
            size_hint_y: None
            height: "56dp"
            md_bg_color: 0.11, 0.13, 0.18, 1

            MDRaisedButton:
                text: "MENU"
                pos_hint: {"x": 0.04, "center_y": 0.5}
                on_release: app.abrir_menu()

            MDLabel:
                text: "Simulador de Push"
                font_style: "H6"
                bold: True
                halign: "center"
                pos_hint: {"center_x": 0.5, "center_y": 0.5}

        MDBoxLayout:
            orientation: 'vertical'
            padding: 20
            spacing: 20

            MDLabel:
                text: "Injete strings idênticas às enviadas pelos sistemas operacionais dos bancos para validar o comportamento do banco de dados."
                font_style: "Body2"
                theme_text_color: "Hint"

            MDTextField:
                id: txt_pacote
                hint_text: "Pacote do App (Ex: com.nu.production)"
                text: "com.nu.production"
                mode: "rectangle"

            MDTextField:
                id: txt_msg
                hint_text: "Texto completo da Notificação"
                text: "Compra aprovada no Mercado Livre: R$ 249,90. Logged."
                mode: "rectangle"

            MDRaisedButton:
                text: "Simular Disparo do Android"
                size_hint_x: 1
                height: "50dp"
                on_release: root.simular_chegada(txt_pacote.text, txt_msg.text)
            
            Widget:
                size_hint_y: 1
                
<TelaConfiguracoes>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: "20dp"
        spacing: "20dp"
        
        MDLabel:
            text: "Permissões de Sistema"
            font_style: "H5"
            halign: "center"
            
        MDRaisedButton:
            text: "Autorizar Leitura de Notificações"
            size_hint_x: 1
            height: "50dp"
            on_release: root.abrir_permissao_android()
            
        MDRaisedButton:
            text: "Voltar"
            size_hint_x: 1
            on_release: app.mudar_tela('visualizacao') # Ou a tela inicial